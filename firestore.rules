rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidMemory(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.type in ['photo', 'voice', 'recipe'] &&
             data.year is int && data.year >= 1800 && data.year <= 2100 &&
             data.author is string && data.author.size() <= 100 &&
             data.media is list && data.media.size() <= 20 &&
             data.star is bool &&
             data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /memories/{memoryId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidMemory(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
                    
      allow update: if isOwner(existing().userId) &&
                    isValidMemory(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
                    
      allow delete: if isOwner(existing().userId);
    }
  }
}
